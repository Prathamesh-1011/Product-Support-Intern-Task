# Groq API key (required for live triage and TAM brief generation)
GROQ_API_KEY=

# Default Groq model used by the project.
GROQ_MODEL=llama-3.3-70b-versatile

# Deterministic generation seed.
GROQ_SEED=42

# Set to true to run the evaluation harness without LLM calls.
EVAL_OFFLINE_MODE=false

# Local data paths.
DATA_DIR=data
KNOWLEDGE_BASE_DIR=knowledge-base
